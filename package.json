{
  "name": "@bloklabs/core",
  "version": "1.2.6",
  "description": "Blok — headless, highly extensible rich text editor built for developers who need to implement a block-based editing experience (similar to Notion) without building it from scratch",
  "module": "dist/blok.mjs",
  "main": "./dist/blok.cjs",
  "browser": "./dist/blok.iife.js",
  "unpkg": "./dist/blok.iife.js",
  "jsdelivr": "./dist/blok.iife.js",
  "types": "./types/index.d.ts",
  "typesVersions": {
    "*": {
      "tools": [
        "./types/tools-entry.d.ts"
      ],
      "full": [
        "./types/full.d.ts"
      ],
      "locales": [
        "./types/locales.d.ts"
      ],
      "markdown": [
        "./types/markdown.d.ts"
      ],
      "icons": [
        "./types/icons.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/blok.mjs",
      "require": "./dist/blok.cjs"
    },
    "./tools": {
      "types": "./types/tools-entry.d.ts",
      "import": "./dist/tools.mjs",
      "require": "./dist/tools.cjs"
    },
    "./full": {
      "types": "./types/full.d.ts",
      "import": "./dist/full.mjs",
      "require": "./dist/full.cjs"
    },
    "./locales": {
      "types": "./types/locales.d.ts",
      "import": "./dist/locales.mjs"
    },
    "./markdown": {
      "types": "./types/markdown.d.ts",
      "import": "./dist/markdown.mjs",
      "require": "./dist/markdown.cjs"
    },
    "./adapters": {
      "import": "./dist/adapters.mjs",
      "require": "./dist/adapters.cjs"
    },
    "./icons": {
      "types": "./types/icons.d.ts",
      "import": "./dist/icons.mjs",
      "require": "./dist/icons.cjs"
    },
    "./umd": {
      "default": "./dist/blok.umd.js"
    }
  },
  "bin": {
    "migrate-from-editorjs": "./codemod/migrate-editorjs-to-blok.js"
  },
  "files": [
    "dist",
    "types",
    "src",
    "codemod",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.9.4",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "blok",
    "text editor",
    "rich text editor",
    "block-based editor",
    "notion-like editor",
    "headless editor",
    "extensible editor"
  ],
  "sideEffects": [
    "./src/components/polyfills.ts",
    "*.css"
  ],
  "scripts": {
    "serve": "vite --no-open",
    "serve:docs": "cd docs && vite --port 8080",
    "build": "node scripts/build-all.mjs",
    "build:angular": "node scripts/build-angular.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "build:test": "node scripts/build-all.mjs --mode test",
    "lint": "sh -c 'ESLINT_CONCURRENCY=off; ESLINT_CACHE=warm; if [ ! -f node_modules/.cache/blok-eslint ]; then ESLINT_CONCURRENCY=4; ESLINT_CACHE=cold; fi; ESLINT_STARTED=$(date +%s); echo \"Lint: ESLint ($ESLINT_CACHE cache, concurrency=$ESLINT_CONCURRENCY)\"; eslint . --concurrency=$ESLINT_CONCURRENCY --cache --cache-location node_modules/.cache/blok-eslint --cache-strategy content; ESLINT_EXIT=$?; ESLINT_SECONDS=$(($(date +%s) - ESLINT_STARTED)); echo \"Lint: ESLint finished in ${ESLINT_SECONDS}s (exit $ESLINT_EXIT)\"; TSC_STARTED=$(date +%s); echo \"Lint: TypeScript (incremental)\"; tsc --noEmit --incremental --tsBuildInfoFile node_modules/.cache/blok-lint.tsbuildinfo; TSC_EXIT=$?; TSC_SECONDS=$(($(date +%s) - TSC_STARTED)); echo \"Lint: TypeScript finished in ${TSC_SECONDS}s (exit $TSC_EXIT)\"; if [ $ESLINT_EXIT -ne 0 ] || [ $TSC_EXIT -ne 0 ]; then exit 1; fi'",
    "lint:fix": "eslint . --fix",
    "lint:tests": "eslint test/",
    "lint:types": "tsc --noEmit",
    "lint:angular": "ngc -p tsconfig.spec.json --noEmit",
    "i18n:audit": "node scripts/i18n-audit.js",
    "i18n:check": "node scripts/i18n/check-translations.mjs",
    "i18n:check:docs": "node scripts/i18n/check-docs-translations.mjs",
    "typography:check": "node scripts/typography-finder/cli.mjs",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=chromium --grep=\"@smoke\"",
    "e2e:chrome": "playwright test --project=chromium",
    "e2e:firefox": "playwright test --project=firefox",
    "e2e:safari": "playwright test --project=webkit",
    "e2e:ui": "playwright test --ui",
    "e2e:ui:chrome": "playwright test --ui --project=chromium",
    "e2e:ui:firefox": "playwright test --ui --project=firefox",
    "e2e:ui:safari": "playwright test --ui --project=webkit",
    "test": "vitest run --project=unit --project=unit-angular",
    "test:watch": "vitest --project=unit --project=unit-angular",
    "test:angular": "vitest run --project=unit-angular",
    "test:coverage": "vitest run --coverage --project=unit",
    "jscpd": "jscpd src/ test/",
    "jscpd:report": "jscpd . --reporters html,json --output .jscpd-report",
    "prepublishOnly": "yarn build",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build --stats-json",
    "storybook:test": "vitest --project=storybook --run",
    "chromatic": "chromatic --exit-zero-on-changes",
    "perf:analyze": "node scripts/analyze-performance.mjs",
    "perf:compare": "node scripts/analyze-performance.mjs --baseline",
    "perf:dashboard": "node scripts/generate-performance-dashboard.mjs",
    "e2e:validate-categories": "node scripts/validate-test-categories.mjs",
    "validate:spec-coverage": "node scripts/validate-spec-file-coverage.mjs",
    "ci:timing": "node scripts/ci-timing-probe.mjs",
    "release": "node scripts/release.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "unused-css": "node scripts/unused-css-finder/cli.mjs"
  },
  "author": "JackUait",
  "contributors": [
    "CodeX (the author of initial solution)"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JackUait/blok.git"
  },
  "devDependencies": {
    "@aiden0z/pptx-renderer": "1.2.4",
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@angular/build": "22.0.7",
    "@angular/common": "22.0.7",
    "@angular/compiler": "22.0.7",
    "@angular/compiler-cli": "22.0.7",
    "@angular/core": "22.0.7",
    "@angular/forms": "22.0.7",
    "@angular/platform-browser": "22.0.7",
    "@angular/platform-server": "22.0.7",
    "@axe-core/playwright": "4.12.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@emoji-mart/data": "^1.2.1",
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@fontsource-variable/source-serif-4": "^5.3.0",
    "@fontsource/permanent-marker": "^5.3.0",
    "@oxc-project/runtime": "0.140.0",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/html-vite": "10.5.2",
    "@tailwindcss/node": "4.3.3",
    "@tailwindcss/vite": "4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "26.1.1",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "@vitest/ui": "4.1.10",
    "@vue/test-utils": "^2.4.11",
    "chromatic": "18.0.1",
    "cldr-annotations-full": "^48.2.0",
    "docx-preview": "0.4.0",
    "dompurify": "^3.4.12",
    "eslint": "10.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsdoc": "63.2.0",
    "eslint-plugin-playwright": "2.10.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-storybook": "10.5.2",
    "eslint-plugin-tailwindcss": "4.2.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "fractional-indexing": "^4.0.0",
    "html-janitor": "2.0.4",
    "husky": "9.1.7",
    "i18next": "26.3.6",
    "jscpd": "4.0.9",
    "jsdom": "29.1.1",
    "jszip": "^3.10.1",
    "katex": "0.18.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-math": "^3.0.0",
    "mermaid": "11.16.0",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-math": "^3.1.0",
    "music-metadata": "^11.14.0",
    "nanoid": "6.0.0",
    "ng-packagr": "22.0.1",
    "playwright": "1.61.1",
    "postcss": "8.5.20",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rollup-plugin-license": "3.7.1",
    "rxjs": "7.8.2",
    "storybook": "10.5.2",
    "tailwindcss": "4.3.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-plugin-css-injected-by-js": "5.0.2",
    "vitest": "4.1.10",
    "vue": "^3.5.40",
    "webm-muxer": "^5.1.4",
    "yaml": "^2.9.0",
    "yjs": "13.6.31",
    "zone.js": "0.15.1"
  },
  "resolutions": {
    "@typescript-eslint/utils": "8.64.0",
    "lodash-es": "^4.18.0"
  }
}
